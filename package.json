{
  "name": "e-commerce-smoke-suite",
  "version": "1.0.0",
  "description": "Playwright smoke test suite for SauceDemo - E-Commerce Optimization & Parallelism",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:chromium": "playwright test --project=chromium",
    "test:report": "playwright show-report",
    "test:trace": "playwright test --trace on",
    "setup": "playwright test --project=setup"
  },
  "devDependencies": {
    "@playwright/test": "^1.43.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
}
